# Скопируйте этот файл в .env и заполните реальными значениями.
# В проде (Railway/VPS) эти же переменные задаются через панель управления
# или systemd unit-файл — .env используется только локально.

# --- Telegram ---
# Токен бота, полученный от @BotFather.
BOT_TOKEN=123456789:AAExampleTokenReplaceMe

# Список Telegram user_id глобальных администраторов бота, через запятую.
# Эти пользователи могут управлять глобальным списком скамеров и имеют
# полный доступ к admin-командам в любом чате, где есть бот.
GLOBAL_ADMIN_IDS=111111111,222222222

# --- База данных ---
# Строка подключения к PostgreSQL. Обязательно используйте asyncpg-драйвер
# (postgresql+asyncpg://, НЕ просто postgresql://).
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/tgmodbot

# --- i18n ---
# Язык по умолчанию для новых чатов, где ещё не выбран язык явно.
DEFAULT_LOCALE=ru
# Язык, на который переключаемся, если перевод отсутствует в основном языке.
FALLBACK_LOCALE=en
# Путь к директории с файлами переводов (*.yml).
LOCALES_DIR=locales

# --- История сообщений (антидубликаты) ---
# Сколько секунд хранить историю сообщений для поиска повторов.
MESSAGE_HISTORY_TTL_SECONDS=86400
# Как часто (в секундах) запускать очистку устаревшей истории.
HISTORY_CLEANUP_INTERVAL_SECONDS=3600

# --- Логирование ---
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# --- Прочее ---
# Сколько секунд ждать штатного завершения фоновых задач при остановке бота.
SHUTDOWN_TIMEOUT_SECONDS=15
